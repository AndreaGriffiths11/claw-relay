{
  "name": "claw-relay",
  "version": "0.1.0",
  "description": "Give your AI agents a real browser. Secure relay between AI agents and Chrome.",
  "main": "relay-server/src/index.ts",
  "bin": {
    "claw-relay": "relay-server/src/cli.ts"
  },
  "files": [
    "relay-server/src/",
    "relay-server/dashboard/dist/",
    "relay-server/package.json",
    "relay-server/tsconfig.json",
    "relay-server/config.example.yaml",
    "mcp/",
    "extension/",
    "docs/",
    "start.sh",
    "LICENSE",
    "README.md",
    "SKILL.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "cd relay-server && npx tsx src/index.ts",
    "dev": "cd relay-server && npx tsx --watch src/index.ts",
    "build": "cd relay-server && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AndreaGriffiths11/claw-relay.git"
  },
  "keywords": ["ai", "agent", "browser", "relay", "chrome", "copilot", "automation", "mcp", "cdp", "playwright", "browser-automation"],
  "author": "Andrea Griffiths",
  "license": "MIT"
}
